# Copy this file to ".env" and fill in your values. Restart the dev server after editing.

# ───────────── Neon Postgres ─────────────
# Neon dashboard → project → "Connect".
#   Connection pooling ON  → POOLED string  (host contains "-pooler")
#   Connection pooling OFF → DIRECT string  (no "-pooler")

# POOLED connection string — used for everything (the app talks to Neon over its
# HTTP driver, so this single pooled URL is all you need).
NEON_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# DIRECT / non-pooled — no longer required by the app. Kept here only if you want
# to run psql/migrations by hand. Safe to leave as a placeholder.
NEON_DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require

# ───────────── Auth ─────────────
JWT_SECRET=change-me-to-a-long-random-string

# ───────────── Google Sign-In (optional) ─────────────
# Same OAuth Client ID in both lines (VITE_ one is exposed to the browser).
GOOGLE_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=YOUR-CLIENT-ID.apps.googleusercontent.com

# ───────────── Push reminders (optional) ─────────────
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Same public key goes in both VAPID_PUBLIC_KEY and VITE_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
VITE_VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
VAPID_PRIVATE_KEY=YOUR-VAPID-PRIVATE-KEY
VAPID_SUBJECT=mailto:you@example.com
# Any random string; protects the daily cron endpoint.
CRON_SECRET=YOUR-RANDOM-CRON-SECRET
# Timezone offset (minutes) for "today" in the reminder. IST = 330.
REMINDER_TZ_OFFSET_MIN=330

# ───────────── Server ─────────────
PORT=3001
